{
  "name": "rglawz",
  "version": "1.0.1",
  "private": true,
  "main": "build/electron.js",
  "homepage": "./",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.14.0",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron:dev": "electron .",
    "electron:build:mac": "react-scripts build && electron-builder --mac",
    "electron:publish:mac": "react-scripts build && electron-builder --mac --publish always"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "build": {
    "appId": "com.rglawz.app",
    "productName": "RGLawz",
    "icon": "public/logo.icns",
    "files": [
      "build/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "public/logo.icns"
    },
    "publish": [
      {
        "provider": "s3",
        "bucket": "rglawz",
        "region": "ap-south-1",
        "path": "/releases",
        "acl": null
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
